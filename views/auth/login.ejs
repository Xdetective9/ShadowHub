<%- include('../layouts/main', { 
    body: `
<div class="container" style="max-width:500px;margin:4rem auto;padding:0 1rem">
    <div class="glass" style="padding:2.5rem">
        <h2 style="text-align:center;margin-bottom:0.5rem">Welcome Back</h2>
        <p style="text-align:center;color:#94a3b8;margin-bottom:2rem">Sign in to continue</p>
        
        <% if (typeof error !== 'undefined' && error) { %>
            <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);padding:0.75rem 1rem;border-radius:8px;color:#fca5a5;margin-bottom:1.5rem">
                <%= error %>
            </div>
        <% } %>
        
        <form method="POST" action="/auth/login">
            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <input type="text" id="username" name="username" class="form-input" required placeholder="Enter username" autocomplete="username">
            </div>
            
            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input type="password" id="password" name="password" class="form-input" required placeholder="Enter password" autocomplete="current-password">
            </div>
            
            <button type="submit" class="btn" style="width:100%;justify-content:center">
                Sign In
            </button>
        </form>
        
        <p style="text-align:center;margin-top:1.5rem;color:#94a3b8">
            Don't have an account? 
            <a href="/auth/signup" style="color:#8b5cf6;text-decoration:none;font-weight:500">Create one</a>
        </p>
        
        <p style="text-align:center;margin-top:1rem">
            <a href="/" style="color:#64748b;text-decoration:none;font-size:0.9rem">← Back to Home</a>
        </p>
    </div>
</div>
    `,
    currentPage: 'login'
}) %>
