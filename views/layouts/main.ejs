<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'ShadowHub' %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/animations.css">
    <%- typeof pluginStyles !== 'undefined' ? pluginStyles : '' %>
    <style>
        /* Plugin-specific overrides */
        <%- typeof pluginInlineStyles !== 'undefined' ? pluginInlineStyles : '' %>
    </style>
</head>
<body>
    <!-- Navigation -->
    <%- include('../partials/header') %>
    
    <!-- Main Content -->
    <main class="container">
        <%- body %>
    </main>
    
    <!-- Footer -->
    <%- include('../partials/footer') %>
    
    <!-- Scripts -->
    <script src="/js/main.js"></script>
    <%- typeof pluginScripts !== 'undefined' ? pluginScripts : '' %>
    <%- typeof pluginInlineScripts !== 'undefined' ? `<script>${pluginInlineScripts}</script>` : '' %>
</body>
</html>
